{
  // Assets-only Worker: ships ./public to the edge.
  // Deploy from the MAIN Cloudflare account (chitransh.aang@gmail.com).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "trivela",
  "account_id": "a82a6302a28c6c2e55c2259f35d17683",
  "compatibility_date": "2024-12-01",
  "assets": { "directory": "./public" },
  "routes": [
    { "pattern": "trivela.pulsar-projects.org", "custom_domain": true }
  ],
  "observability": { "enabled": true }
}
